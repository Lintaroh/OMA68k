   40/     43A :                        
   41/     43A :                        	;; 2. VBlankステータスリードテスト
   42/     43A :                        	;; V9938はPort 1 (Command Port)を読むと、Status Register 0が読めます。
   43/     43A :                        	;; bit 7にV-Blankフラグがあり、約1/60秒ごとに1になり、読むと0クリアされます。
   44/     43A :                        	;; データバスが逆順なら bit 0 に現れる可能性があります。
   45/     43A :                        	;; ここでは、Even($A0002)とOdd($A0003)の両方のポートを少しの間監視し、
   46/     43A :                        	;; 値が変化したら出力します。
   47/     43A :                        	
   48/     43A :                        	;; --- Even側の監視 ($A0002) ---
   49/     43A : 41F8 04DE              	LEA	MSG_STAT_EVEN,A0
   50/     43E : 4EB9 0008 0752         	JSR	STROUT
   51/     444 : 227C 000A 0002         	MOVE.L	#$0A0002,A1
   52/     44A : 611E                   	BSR	MONITOR_PORT
   53/     44C :                        
   54/     44C :                        	;; --- Odd側の監視 ($A0003) ---
   55/     44C : 41F8 0503              	LEA	MSG_STAT_ODD,A0
   56/     450 : 4EB9 0008 0752         	JSR	STROUT
   57/     456 : 227C 000A 0003         	MOVE.L	#$0A0003,A1
   58/     45C : 610C                   	BSR	MONITOR_PORT
   59/     45E :                        
   60/     45E :                        	;; テスト終了、モニタに制御を戻す (RTS)
