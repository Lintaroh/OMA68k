    9048/   8750E :                     ;prg_strt
    9049/   8750E :                     
    9050/   8750E :                     ;************************************************************************************
    9051/   8750E :                     ; EhBASIC keywords quick reference list												*
    9052/   8750E :                     ;************************************************************************************
    9053/   8750E :                     
    9054/   8750E :                     ; glossary
    9055/   8750E :                     
    9056/   8750E :                     ;		<.>		  required
    9057/   8750E :                     ;		{.|.}		  one of required
    9058/   8750E :                     ;		[.]		  optional
    9059/   8750E :                     ;		...		  may repeat as last
    9060/   8750E :                     
    9061/   8750E :                     ;		any		= anything
    9062/   8750E :                     ;		num		= number
    9063/   8750E :                     ;		state		= statement
    9064/   8750E :                     ;		n		= positive integer
    9065/   8750E :                     ;		str		= string
    9066/   8750E :                     ;		var		= variable
    9067/   8750E :                     ;		nvar		= numeric variable
    9068/   8750E :                     ;		svar		= string variable
    9069/   8750E :                     ;		expr		= expression
    9070/   8750E :                     ;		nexpr		= numeric expression
    9071/   8750E :                     ;		sexpr		= string expression
    9072/   8750E :                     
    9073/   8750E :                     ; statement separator
    9074/   8750E :                     
    9075/   8750E :                     ; :			. [<state>] : [<state>]							; done
    9076/   8750E :                     
    9077/   8750E :                     ; number bases
    9078/   8750E :                     
    9079/   8750E :                     ; %			. %<binary num>								; done
    9080/   8750E :                     ; $			. $<hex num>								; done
    9081/   8750E :                     
    9082/   8750E :                     ; commands
    9083/   8750E :                     
    9084/   8750E :                     ; END		. END										; done
    9085/   8750E :                     ; FOR		. FOR <nvar>=<nexpr> TO <nexpr> [STEP <nexpr>]	; done
    9086/   8750E :                     ; NEXT		. NEXT [<nvar>[,<nvar>]...]						; done
    9087/   8750E :                     ; DATA		. DATA [{num|["]str["]}[,{num|["]str["]}]...]	; done
    9088/   8750E :                     ; INPUT		. INPUT [<">str<">;] <var>[,<var>[,<var>]...]	; done
    9089/   8750E :                     ; DIM		. DIM <var>(<nexpr>[,<nexpr>[,<nexpr>]])		; done
    9090/   8750E :                     ; READ		. READ <var>[,<var>[,<var>]...]				; done
    9091/   8750E :                     ; LET		. [LET] <var>=<expr>						; done
    9092/   8750E :                     ; DEC		. DEC <nvar>[,<nvar>[,<nvar>]...]			; done
    9093/   8750E :                     ; GOTO		. GOTO <n>									; done
    9094/   8750E :                     ; RUN		. RUN [<n>]									; done
    9095/   8750E :                     ; IF		. IF <expr>{GOTO<n>|THEN<{n|comm}>}[ELSE <{n|comm}>]	; done
    9096/   8750E :                     ; RESTORE	. RESTORE [<n>]								; done
    9097/   8750E :                     ; GOSUB		. GOSUB <n>									; done
    9098/   8750E :                     ; RETURN	. RETURN									; done
    9099/   8750E :                     ; REM		. REM [<any>]								; done
    9100/   8750E :                     ; STOP		. STOP										; done
    9101/   8750E :                     ; ON		. ON <nexpr>{GOTO|GOSUB}<n>[,<n>[,<n>]...]	; done
    9102/   8750E :                     ; NULL		. NULL <nexpr>								; done
    9103/   8750E :                     ; INC		. INC <nvar>[,<nvar>[,<nvar>]...]			; done
