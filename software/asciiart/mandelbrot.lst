   81/     424 : 3404                           MOVE.W  D4,D2           ; D2 = CR  (will not change)
   82/     426 : 3606                           MOVE.W  D6,D3           ; D3 = CI  (will not change)
   83/     428 :                                ;;; D4 = iteration counter  (we just saved D4 on stack)
   84/     428 : 383C 0040                      MOVE.W  #MAXITER,D4
   85/     42C :                        
