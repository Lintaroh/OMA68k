   52/       0 : =$8141A                CONOUT  EQU     $8141A
   53/       0 : =$813FA                CONIN   EQU     $813FA
   54/       0 : =$8140E                CONST   EQU     $8140E
   55/       0 : =$8079E                STROUT  EQU     $8079E
   56/       0 : =$80812                CRLF    EQU     $80812
   57/       0 :                        
