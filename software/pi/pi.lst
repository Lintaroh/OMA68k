    1/       0 :                        ;;; ============================================================
    2/       0 :                        ;;;   pi.asm  -  Infinite Pi Digit Generator (Spigot Algorithm)
    3/       0 :                        ;;;   MC68008/68000
    4/       0 :                        ;;;
    5/       0 :                        ;;;   Streams decimal digits of pi to the serial console forever.
    6/       0 :                        ;;;   Based on the unbounded spigot algorithm by Gibbons (2006),
    7/       0 :                        ;;;   using the continued-fraction / LFT composition method.
    8/       0 :                        ;;;
    9/       0 :                        ;;;   Algorithm overview:
   10/       0 :                        ;;;     Pi can be expressed as the composition of an infinite
   11/       0 :                        ;;;     sequence of Moebius (linear fractional) transformations:
   12/       0 :                        ;;;       T_k = ( k, 4*k+2, 0, 2*k+1 )   for k = 1, 2, 3, ...
   13/       0 :                        ;;;
   14/       0 :                        ;;;     We maintain a composed transformation Z = (q, r, s, t)
   15/       0 :                        ;;;     starting from the identity (1, 0, 0, 1).
   16/       0 :                        ;;;
   17/       0 :                        ;;;     At each step:
   18/       0 :                        ;;;       1. Extract a trial digit: d = floor( (3*q + r) / (3*s + t) )
   19/       0 :                        ;;;          (safe estimate using floor( (q*3+r) / (s*3+t) ))
   20/       0 :                        ;;;       2. Check safety:  d == floor( (4*q + r) / (4*s + t) ) ?
   21/       0 :                        ;;;          (i.e. floor( (q*4+r) / (s*4+t) ))
   22/       0 :                        ;;;       3. If safe:
   23/       0 :                        ;;;            - Output digit d
   24/       0 :                        ;;;            - Update Z by "consuming" the digit:
   25/       0 :                        ;;;              Z' = ( 10*(q - d*s), 10*(r - d*t), s, t )
   26/       0 :                        ;;;       4. If not safe:
   27/       0 :                        ;;;            - "Produce" (compose) the next T_k into Z:
   28/       0 :                        ;;;              Z' = ( q*k, q*(4*k+2) + r*(2*k+1),
   29/       0 :                        ;;;                      s*k, s*(4*k+2) + t*(2*k+1) )
   30/       0 :                        ;;;              then increment k.
   31/       0 :                        ;;;
   32/       0 :                        ;;;   All arithmetic uses 32-bit signed integers.
   33/       0 :                        ;;;   When values overflow, the algorithm gracefully wraps and
   34/       0 :                        ;;;   will produce incorrect digits eventually, but for a 68000
   35/       0 :                        ;;;   with 32-bit MULS (16x16->32) this gives many correct digits.
   36/       0 :                        ;;;
   37/       0 :                        ;;;   To handle larger ranges, we use a software multiply
   38/       0 :                        ;;;   routine (MUL32) that does full 32x32->32 multiplication.
   39/       0 :                        ;;;
   40/       0 :                        ;;;   Monitor I/O  (from Monitor/unimon_68000.lst):
   41/       0 :                        ;;;     CONOUT = $0008141A   (D0.B = char to output)
   42/       0 :                        ;;;     CONIN  = $000813FA   (returns D0.B = char)
   43/       0 :                        ;;;     CONST  = $0008140E   (D0.B != 0 if key pressed)
   44/       0 :                        ;;;     STROUT = $0008079E   (A0 = ptr to null-terminated string)
   45/       0 :                        ;;;     CRLF   = $00080812   (outputs CR+LF)
   46/       0 :                        ;;; ============================================================
   47/       0 :                        
   48/       0 :                                CPU     68000
   49/       0 :                                SUPMODE ON
   50/       0 :                        
